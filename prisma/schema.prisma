generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id          String       @id @default(cuid())
  name        String
  email       String       @unique
  password    String
  role        Role         @default(DESIGNER)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  submissions Quote[]      @relation("DesignerSubmissions")

  @@map("users")
}

model Brand {
  id           String      @id @default(cuid())
  name         String
  email        String      @unique
  phone        String
  password     String
  status       BrandStatus @default(ACTIVE)
  quotes       Quote[]
  matrixCells  PricingMatrixCell[]
  hiringPosts  HiringPost[]

  // Profile details
  coverImage   String?
  logo         String?
  description  String?
  addressLine1 String?
  addressLine2 String?
  locality     String?
  city         String?
  state        String?
  pincode      String?
  latitude     String?
  longitude    String?
  website      String?
  linkedin     String?
  facebook     String?
  twitter      String?
  instagram    String?
  portfolio    String?     // JSON string storing projects & media urls

  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  @@map("brands")
}

model Quote {
  id             String           @id @default(cuid())
  brand          Brand?           @relation(fields: [brandId], references: [id], onDelete: Cascade)
  brandId        String?
  designer       User?            @relation("DesignerSubmissions", fields: [designerId], references: [id], onDelete: SetNull)
  designerId     String?
  projectName    String
  status         QuoteStatus      @default(SUBMITTED)
  quotationWindowHours Int?
  quotationExpiresAt DateTime?
  referenceImage String?
  items          SubmissionItem[]
  designerBudget Float?
  parentQuoteId  String?
  parentQuote    Quote?           @relation("QuoteToQuote", fields: [parentQuoteId], references: [id], onDelete: SetNull)
  childQuotes    Quote[]          @relation("QuoteToQuote")
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  @@map("quotes")
}

model SubmissionItem {
  id             String   @id @default(cuid())
  quote          Quote    @relation(fields: [quoteId], references: [id], onDelete: Cascade)
  quoteId        String
  description    String
  quantity       Int      @default(1)
  notes          String?
  pricePerSft    Float?
  itemType       String?
  hardware       String?
  coreMaterial   String?
  externalFinish String?
  sft            Float?
  createdAt      DateTime @default(now())

  @@map("submission_items")
}

model AuditLog {
  id          String   @id @default(cuid())
  action      String
  entityType  String
  entityId    String
  performedBy String
  details     String?
  createdAt   DateTime @default(now())

  @@map("audit_logs")
}

enum Role {
  ADMIN
  DESIGNER
}

enum BrandStatus {
  ACTIVE
  INACTIVE
  PENDING
}

enum QuoteStatus {
  DRAFT
  SUBMITTED
  APPROVED
  REJECTED
  ACTIVE
}

model PricingMatrixCell {
  id             String   @id @default(cuid())
  brand          Brand    @relation(fields: [brandId], references: [id], onDelete: Cascade)
  brandId        String
  code           Int      // 1 or 2
  hardware       String   // EBCO, HETTICH, HAFELE
  coreMaterial   String   // MR Ply, BWP Ply, HDHMR
  externalFinish String   // Laminate, Acrylic, PU
  price          Float
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([brandId, code, hardware, coreMaterial, externalFinish])
  @@map("pricing_matrix_cells")
}

model HiringPost {
  id          String   @id @default(cuid())
  brand       Brand    @relation(fields: [brandId], references: [id], onDelete: Cascade)
  brandId     String
  title       String
  description String
  role        String
  location    String?
  salary      String?
  contactInfo String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("hiring_posts")
}
